{
  "name": "renci",
  "private": true,
  "workspaces": ["apps/web"],
  "scripts": {
    "dev:web": "cd apps/web && npm run dev",
    "dev:api": "cd apps/api && uvicorn main:app --reload --port 8000",
    "build:web": "cd apps/web && npm run build",
    "test:api": "cd apps/api && pytest",
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\""
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
